# ============================================================
# AI VoiceBridge 1092 — Node Backend — EXAMPLE ENV FILE
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real values below.
# 3. Never commit the actual .env file.
# ============================================================

# Server port (default: 8000)
PORT=8000

# Supabase — SERVICE ROLE key (admin, bypasses RLS — server only)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Groq API — used for Whisper STT and Llama 3.3 LLM
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs TTS — proxied server-side to keep key secret
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
