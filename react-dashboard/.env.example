# ============================================================
# AI VoiceBridge 1092 — React Dashboard — EXAMPLE ENV FILE
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real values below.
# 3. Never commit the actual .env file.
#
# VITE_ prefix is required for Vite to expose vars to browser.
# Only put PUBLIC (anon/publishable) keys here.
# ============================================================

# Supabase — ANON (public) key — safe for browser, restricted by RLS
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Node backend base URL (used for API calls from React)
VITE_API_BASE_URL=http://localhost:8000
